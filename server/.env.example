# PostgreSQL 数据库连接配置模板
# 复制此文件为 .env，并根据您本地的 PostgreSQL 配置修改参数

DB_HOST=localhost
DB_PORT=5432
DB_NAME=community_booking
DB_USER=postgres
DB_PASSWORD=your_password_here

# Redis 配置（用于登录会话存储）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 会话过期时间（秒），默认 24 小时
SESSION_TTL=86400

# 管理员默认账号密码
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# 服务端口
PORT=5001
